# Copy outside the repository and fill machine-local paths. Do not commit it.
export OPENPI_ROOT=/path/to/openpi
export INFER_ROOT=/path/to/openpi_inference
export TARGET_LIBERO_PATH=/path/to/LIBERO/libero
export ROBOMEMARENA_REMOTE_ROOT=/path/to/RoboMemArena-pinned-6221403
export VLA_POLICY=/path/to/original-fullvlmv2-35999
export VLA_CONFIG=pi05_libero_robomemarena_fullvlm_v2_noflip_dataset
export VLA_REPO_ID=/path/to/original-fullvlmv2-norm-repository
export VLM_CKPT=/path/to/task22-vlm-checkpoint
# Task22 v3 data augmentation inputs. Keep actual paths in an ignored local env file.
TASK22_V3_SOURCE_JSONL=/absolute/path/to/original/task22.jsonl
TASK22_V3_OUTPUT_JSONL=/absolute/path/to/output/task22_v3_native_boundary.jsonl
TASK22_V3_MANIFEST=/absolute/path/to/output/task22_v3_native_boundary.manifest.json
