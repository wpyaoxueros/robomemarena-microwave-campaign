# Copy to .env and replace every path with a local value. Do not commit .env.
export OPENPI_ROOT=/path/to/openpi
export INFER_ROOT=/path/to/openpi_inference
export TARGET_LIBERO_PATH=/path/to/LIBERO/libero
export ROBOMEMARENA_REMOTE_ROOT=/path/to/RoboMemArena
export TASK21_DATA_ROOT=/path/to/21_butter_chocolate_microwave_dataset/subtask_data

# Required model locations. They are intentionally not embedded in this repository.
export VLA_POLICY=/path/to/vla/checkpoint
export VLM_CKPT=/path/to/vlm/checkpoint

# This package provides the frozen norm by default. Override only when using the
# exact matching norm repository elsewhere.
# export VLA_REPO_ID=/path/to/lerobot/norm/repository

# Optional output destination. Defaults to ./outputs under this repository.
# export OUTPUT_ROOT=/path/to/output
