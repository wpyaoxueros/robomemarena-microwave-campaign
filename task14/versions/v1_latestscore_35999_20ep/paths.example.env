# Copy to .env and replace each value with a local path. Do not commit .env.
export OPENPI_ROOT=/path/to/openpi
export INFER_ROOT=/path/to/openpi_inference
export TARGET_LIBERO_PATH=/path/to/RoboMemArena/evaluation_benchmark/libero_fork
export ROBOMEMARENA_REMOTE_ROOT=/path/to/RoboMemArena

# Model weights are supplied outside this repository.
export VLA_POLICY=/path/to/vla/checkpoint/35999
export VLM_CKPT=/path/to/task14/vlm/checkpoint

# The matching norm is tracked in assets/norm_repo by default.
# export VLA_REPO_ID=/path/to/norm/repository
# export OUTPUT_ROOT=/path/to/task14/output
