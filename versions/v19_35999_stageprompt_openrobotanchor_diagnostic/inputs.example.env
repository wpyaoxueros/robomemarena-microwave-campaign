# Copy this ignored file to inputs.env and fill the historical private paths.
export OPENPI_ROOT=/path/to/openpi
export INFER_ROOT=/path/to/openpi_inference
export TARGET_LIBERO_PATH=/path/to/LIBERO/libero
export VLM_CKPT=/path/to/historical-task22-vlm
export VLA_POLICY=/path/to/historical-task22-vla
export VLA_CONFIG=pi05_libero_robomemarena_fullvlm_v2_noflip_dataset
# v15 derives VLA_REPO_ID from the original checkpoint's built-in asset. Keep
# this line only for compatibility with shared private input files.
export VLA_REPO_ID=/path/to/unused-external-norm-repository
