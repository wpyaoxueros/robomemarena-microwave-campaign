# Copy this file to .env and replace every value with a local path.
# Do not commit .env or model weights.
export OPENPI_ROOT=/path/to/openpi
export INFER_ROOT=/path/to/openpi_inference
export TARGET_LIBERO_PATH=/path/to/LIBERO/libero
export ROBOMEMARENA_REMOTE_ROOT=/path/to/RoboMemArena-at-514ecdf
export TASK20_DATA_ROOT=/path/to/20_cookies_chocolate_microwave_dataset/subtask_data

# Required model locations. This repository intentionally contains only
# identifiers in FROZEN_PROVENANCE.md, not the original machine paths.
export VLA_POLICY=/path/to/vla/checkpoint
export VLM_CKPT=/path/to/vlm/checkpoint

# Optional output location. Defaults to ./outputs in this package.
# export OUTPUT_ROOT=/path/to/output
