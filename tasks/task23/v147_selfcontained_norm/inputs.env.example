# Copy to inputs.env. Do not commit inputs.env.
# Paths are machine-local and deliberately excluded from Git history.

export OPENPI_ROOT=/path/to/openpi
export INFER_ROOT=/path/to/openpi_inference
export TARGET_LIBERO_PATH=/path/to/RoboMemArena/LIBERO/libero
export ROBOMEMARENA_REMOTE_ROOT=/path/to/RoboMemArena-pinned-6221403

# Use labels from the experiment ledger; resolve them to local paths here.
export VLA_POLICY=/path/to/original-fullvlmv2-35999
# Leave VLA_REPO_ID unset to use this package's exact original norm asset.
# If overridden, its basename must match the asset ID installed in VLA_POLICY/assets.
export VLM_CKPT=/path/to/task23-v144-checkpoint-400

export OUT_BASE=/path/to/output
export SEED=104
export NUM_TRIALS=1
export MAX_STEPS=2000
export REPLAN_STEPS=5
export PORT=9723
